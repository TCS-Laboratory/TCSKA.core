<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      metal:use-macro="here/main_template/macros/master"
      i18n:domain="senaite.core">

  <body>
    <!-- Page Title -->
    <metal:content-title fill-slot="content-title">
      <h1 class="d-flex align-items-center">
        <i class="referencesample-icon mr-2" title="Reference Sample" i18n:attributes="title">
          <svg tal:replace="structure senaite_theme/icon_data/referencesample" />
        </i>
        <span class="documentFirstHeading" tal:content="context/title"></span>
      </h1>
      <h2 tal:content="view/title" class="h5 text-muted mt-2"></h2>
    </metal:content-title>

    <metal:content-description fill-slot="content-description">
      <!-- Optional additional description block -->
    </metal:content-description>

    <metal:content-core fill-slot="content-core">

      <!-- Chart Controls and Container -->
      <div class="row mb-4">
        <div class="col-sm-12">
          <div class="card p-3 shadow-sm">
            <form class="form-inline flex-wrap">
              <div class="form-group mr-3 mb-2">
                <label for="selanalyses" class="mr-2 mb-0" i18n:translate="">Analysis</label>
                <select id="selanalyses" name="selanalyses" class="form-control form-control-sm"></select>
              </div>

              <div class="form-group mr-3 mb-2">
                <label for="selqcsample" class="mr-2 mb-0" i18n:translate="">Reference Sample</label>
                <select id="selqcsample" name="selqcsample" class="form-control form-control-sm"></select>
              </div>

              <div class="form-group mr-3 mb-2">
                <label for="interpolation" class="mr-2 mb-0" i18n:translate="">Interpolation</label>
                <select id="interpolation" name="interpolation" class="form-control form-control-sm">
                  <option value="basis" i18n:translate="" selected>Basis</option>
                  <option value="cardinal" i18n:translate="">Cardinal</option>
                  <option value="linear" i18n:translate="">Linear</option>
                </select>
              </div>

              <div class="form-group mb-2">
                <a id="printgraph" class="btn btn-sm btn-outline-secondary" href="#" i18n:translate="">
                  Print
                </a>
              </div>
            </form>

            <div id="chart" class="mt-4"></div>
          </div>
        </div>
      </div>

      <!-- Reference Analyses Table -->
      <div class="row">
        <div class="col-sm-12">
          <tal:referenceanalyses define="table view/get_analyses_table_view">
            <span tal:replace="structure python:table.ajax_contents_table()" />
            <input type="hidden" id="graphdata" tal:attributes="value python:table.chart.get_json()" />
          </tal:referenceanalyses>
        </div>
      </div>

    </metal:content-core>
  </body>
</html>

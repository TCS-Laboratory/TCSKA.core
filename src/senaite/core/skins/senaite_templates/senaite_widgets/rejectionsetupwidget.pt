<html xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      i18n:domain="senaite.core">

  <!-- View macro uses string widget rendering -->
  <metal:view_macro define-macro="view">
    <div metal:use-macro="here/widgets/string/macros/view"></div>
  </metal:view_macro>

  <!-- Edit macro -->
  <metal:define define-macro="edit"
                tal:define="widget_data python:request.form.get(fieldName, accessor());
                            options python:widget_data[0] if len(widget_data) > 0 else {};">
    <div class="form-group"
         tal:attributes="id string:archetypes-fieldname-${fieldName};
                         class python:'%s %s' % ('field', widget.getName())">

      <!-- Checkbox with label -->
      <div class="mb-2">
        <input type="checkbox"
               class="form-check-input rejectionwidget-checkbox"
               tal:attributes="name string:${fieldName}.checkbox:records:ignore_empty;
                               id string:${fieldName}-checkbox;
                               checked python:'checked' if len(options) > 1 and 'checkbox' in options and options['checkbox']  == 'on' else ''"/>
        <label class="form-check-label" tal:attributes="for string:${fieldName}-checkbox">
          <span i18n:translate="" tal:replace="python:widget.Label(here)"></span>
        </label>
        <small class="form-text text-muted" tal:attributes="id python: fieldName + '_help'"
               tal:content="python:widget.Description(here)"></small>
      </div>

      <!-- Rejection reasons container -->
      <div class="rejectionwidget-container bg-light p-3 rounded border">

        <!-- Header and help -->
        <label class="font-weight-bold d-block" i18n:translate="">
          Predefined Rejection Reasons
        </label>
        <small class="form-text text-muted mb-2" i18n:translate="">
          These reasons will be available for selection during the rejection process.
        </small>

        <!-- Rejection reasons list -->
        <div class="options-set" id="options-set">
          <span tal:repeat="option python:widget.getSortKeys(options.keys())"
                tal:omit-tag="python:True">
            <div class="option-set input-group mb-2"
                 tal:condition="python:option != 'checkbox'"
                 tal:attributes="id string:${fieldName}-option-${repeat/option/index}">
              <input type="text"
                     class="form-control form-control-sm"
                     tal:attributes="name string:${fieldName}.textfield-${repeat/option/index}:records:ignore_empty;
                                     id string:${fieldName}-textfield-${repeat/option/index};
                                     value python:options[option] if option in options.keys() else ''"
                     size="30"
                     tabindex="#" />
              <div class="input-group-append">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary rej_deletebtn"
                        title="Delete"
                        i18n:attributes="title">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>
          </span>
        </div>

        <!-- More button -->
        <div class="mt-2">
          <input type="button"
                 class="btn btn-sm btn-outline-secondary"
                 value="More"
                 tal:attributes="id string:${fieldName}_more;
                                 tabindex tabindex/next|nothing"
                 i18n:attributes="value" />
        </div>
      </div>
    </div>
  </metal:define>

  <!-- Search macro delegates to string widget search -->
  <div metal:define-macro="search">
    <div metal:use-macro="here/widgets/string/macros/search"></div>
  </div>
</html>

<html xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      i18n:domain="senaite.core">

  <metal:view_macro define-macro="view">
    <div metal:define-macro="textarea-field-view"
         tal:define="uid context/UID|nothing;
                     portal_state context/@@plone_portal_state;
                     portal portal_state/portal;
                     history accessor"
         tal:condition="history"
         tal:attributes="id string:parent-fieldname-$fieldName-$uid"
         class="remarks_history remarks-widget my-4">

      <tal:static define="static_path string:${portal/absolute_url}/senaite_widgets">
        <link rel="stylesheet" type="text/css" media="all"
              tal:attributes="href string:${static_path}/remarkswidget.css"/>
      </tal:static>

      <div class="remarks_history">
        <tal:record repeat="record history">
          <div class="record my-4" tal:attributes="id record/id;">
            <div class="record-header small text-muted border-bottom mb-1 pb-1 d-flex flex-wrap"
                 tal:condition="record/user_id">
              <span class="record-user font-weight-bold pr-2" tal:content="record/user_id"/>
              <span class="record-username pr-2" tal:content="record/user_name"/>
              <span class="record-date pr-2" tal:content="record/created_ulocalized"/>
            </div>
            <div class="record-content" tal:content="structure record/html_content"></div>
          </div>
        </tal:record>
      </div>
    </div>
  </metal:view_macro>

  <metal:remarks_edit define-macro="remarks_edit">
    <tal:static define="static_path string:${portal/absolute_url}/senaite_widgets">
      <script type="text/javascript"
              tal:attributes="src string:${static_path}/remarkswidget.js"></script>
      <link rel="stylesheet" type="text/css" media="all"
            tal:attributes="href string:${static_path}/remarkswidget.css"/>
    </tal:static>

    <div class="remarks-widget my-4">
      <textarea class="form-control"
                tal:attributes="name fieldName; id fieldName;"></textarea>

      <div tal:condition="python: 'portal_factory' not in context.absolute_url()">
        <input class="saveRemarks allowMultiSubmit btn btn-primary btn-sm mt-2 mb-4"
               type="submit"
               value="Add remarks"
               disabled="disabled"
               i18n:attributes="value"
               i18n:domain="senaite.core"/>
      </div>
    </div>
  </metal:remarks_edit>

  <metal:remarks_history define-macro="remarks_history">
    <div class="remarks_history remarks-widget my-4">
      <tal:records define="records python:field.get_history(context)">
        <tal:block repeat="record python:records">
          <div class="record my-4"
               tal:attributes="id record/id;
                               class python:'record my-4 ' + ('d-none extra-remark' if repeat['record'].index >= 1 else '')">
            <div class="record-header small text-muted border-bottom mb-1 pb-1 d-flex flex-wrap"
                 tal:condition="record/user_id">
              <span class="record-user font-weight-bold pr-2" tal:content="record/user_id"/>
              <span class="record-username pr-2" tal:content="record/user_name"/>
              <span class="record-date pr-2" tal:content="record/created_ulocalized"/>
            </div>
            <div class="record-content" tal:content="structure record/html_content"></div>
          </div>
        </tal:block>
        <div tal:condition="python:len(records) > 1" class="mt-3">
          <button type="button"
                  class="toggleRemarks btn btn-link btn-sm p-0">
            <span class="show-more-text" i18n:translate="">Show more</span>
            <span class="show-less-text d-none" i18n:translate="">Show less</span>
          </button>
        </div>
      </tal:records>
    </div>
  </metal:remarks_history>

  <metal:edit define-macro="edit">
    <metal:use use-macro="field_macro | context/widgets/field/macros/edit">
      <metal:fill fill-slot="widget_body">
        <metal:block use-macro="context/senaite_widgets/remarkswidget/macros/remarks_history"/>
        <metal:block use-macro="context/senaite_widgets/remarkswidget/macros/remarks_edit"/>
      </metal:fill>
    </metal:use>
  </metal:edit>

  <metal:search define-macro="search">
    <metal:use use-macro="context/widgets/field/macros/edit">
      <metal:fill fill-slot="widget_body">
        <metal:block use-macro="context/widgets/remarkswidget/macros/remarks_edit"/>
      </metal:fill>
    </metal:use>
  </metal:search>

</html>

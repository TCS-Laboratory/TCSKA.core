<div id="senaite-aichat-root"
     tal:attributes="data-endpoint view/endpoint">
  <style>
    #senaite-aichat-root * { box-sizing: border-box; }
    #senaite-aichat-toggle {
      position: fixed; right: 22px; bottom: 22px; z-index: 99999;
      width: 60px; height: 60px; border-radius: 50%;
      background: linear-gradient(135deg, #1f4e79 0%, #2a6fa3 100%);
      color: #fff; border: 0; cursor: pointer; padding: 0;
      box-shadow: 0 6px 18px rgba(31,78,121,.40);
      display: flex; align-items: center; justify-content: center;
      transition: transform .15s ease, box-shadow .15s ease;
    }
    #senaite-aichat-toggle:hover {
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 10px 24px rgba(31,78,121,.5);
    }
    #senaite-aichat-toggle svg { width: 28px; height: 28px; }

    #senaite-aichat-panel {
      position: fixed; right: 22px; bottom: 94px; z-index: 99999;
      width: 390px; height: 580px; max-height: calc(100vh - 130px);
      background: #fff; border-radius: 16px; overflow: hidden;
      box-shadow: 0 18px 50px rgba(15,40,70,.28);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      flex-direction: column;
      animation: atlas-pop .18s ease-out;
    }
    @keyframes atlas-pop {
      from { opacity: 0; transform: translateY(12px) scale(.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    #senaite-aichat-panel[hidden] { display: none; }
    #senaite-aichat-panel:not([hidden]) { display: flex; }

    #senaite-aichat-panel .hdr {
      background: linear-gradient(135deg, #1f4e79 0%, #2a6fa3 100%);
      color: #fff; padding: 14px 16px; display: flex; align-items: center;
      gap: 12px;
    }
    #senaite-aichat-panel .hdr .ava {
      position: relative;
      width: 38px; height: 38px; border-radius: 50%;
      background: rgba(255,255,255,.18); display: flex;
      align-items: center; justify-content: center; font-weight: 700;
      font-size: 16px; letter-spacing: .5px; flex: 0 0 auto;
    }
    #senaite-aichat-panel .hdr .ava .st {
      position: absolute; right: -1px; bottom: -1px;
      width: 11px; height: 11px; border-radius: 50%;
      background: #5ee08a; border: 2px solid #235f8c;
    }
    #senaite-aichat-panel .hdr .meta { flex: 1; min-width: 0; line-height: 1.3; }
    #senaite-aichat-panel .hdr .meta .name {
      font-weight: 700; font-size: 15px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    #senaite-aichat-panel .hdr .meta .sub {
      font-size: 11.5px; opacity: .85;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    #senaite-aichat-panel .hdr .x {
      background: transparent; border: 0; color: #fff; cursor: pointer;
      font-size: 20px; line-height: 1; opacity: .8; padding: 4px;
    }
    #senaite-aichat-panel .hdr .x:hover { opacity: 1; }

    #senaite-aichat-log {
      flex: 1; overflow-y: auto; padding: 14px;
      background: #f6f8fb; font-size: 13.5px; line-height: 1.5;
    }
    #senaite-aichat-log .row { display: flex; margin-bottom: 12px; gap: 8px; }
    #senaite-aichat-log .row.user { justify-content: flex-end; }
    #senaite-aichat-log .av {
      width: 26px; height: 26px; border-radius: 50%; flex: 0 0 auto;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: #fff;
      background: linear-gradient(135deg,#1f4e79,#2a6fa3);
    }
    #senaite-aichat-log .row.user .av { display: none; }
    #senaite-aichat-log .bubble {
      padding: 9px 12px; border-radius: 14px; max-width: 80%;
      word-wrap: break-word; overflow-wrap: anywhere;
      box-shadow: 0 1px 2px rgba(15,40,70,.06);
    }
    #senaite-aichat-log .bot .bubble {
      background: #fff; color: #1f2933; border-bottom-left-radius: 4px;
    }
    #senaite-aichat-log .user .bubble {
      background: linear-gradient(135deg,#1f4e79,#2a6fa3); color: #fff;
      border-bottom-right-radius: 4px;
    }
    #senaite-aichat-log .bubble strong { font-weight: 700; }
    #senaite-aichat-log .bubble ul { margin: 4px 0 4px 0; padding-left: 18px; }
    #senaite-aichat-log .bubble li { margin: 1px 0; }
    #senaite-aichat-log .bubble div { margin: 1px 0; }

    #senaite-aichat-log .typing span {
      display: inline-block; width: 7px; height: 7px; margin: 0 1px;
      background: #9aa5b1; border-radius: 50%; animation: atlas-blink 1.2s infinite;
    }
    #senaite-aichat-log .typing span:nth-child(2) { animation-delay: .2s; }
    #senaite-aichat-log .typing span:nth-child(3) { animation-delay: .4s; }
    @keyframes atlas-blink { 0%,60%,100%{opacity:.25;} 30%{opacity:1;} }

    #senaite-aichat-chips {
      padding: 0 14px 8px; background: #f6f8fb; display: flex;
      flex-wrap: wrap; gap: 6px;
    }
    #senaite-aichat-chips button {
      border: 1px solid #d6e0ec; background: #fff; color: #2a6fa3;
      border-radius: 14px; padding: 4px 10px; font-size: 11.5px;
      cursor: pointer; white-space: nowrap;
    }
    #senaite-aichat-chips button:hover { background: #eef4fb; }

    #senaite-aichat-input-row {
      display: flex; align-items: center; gap: 8px;
      border-top: 1px solid #e6ebf1; padding: 10px 12px; background: #fff;
    }
    #senaite-aichat-input {
      flex: 1; border: 1px solid #d6dee7; border-radius: 22px;
      padding: 9px 14px; font-size: 13.5px; outline: none;
    }
    #senaite-aichat-input:focus { border-color: #2a6fa3; box-shadow: 0 0 0 3px rgba(42,111,163,.12); }
    #senaite-aichat-send {
      width: 38px; height: 38px; flex: 0 0 auto; border: 0; cursor: pointer;
      border-radius: 50%; color: #fff;
      background: linear-gradient(135deg,#1f4e79,#2a6fa3);
      display: flex; align-items: center; justify-content: center;
    }
    #senaite-aichat-send:disabled { opacity: .5; cursor: default; }
    #senaite-aichat-send svg { width: 18px; height: 18px; }
  </style>

  <button id="senaite-aichat-toggle" type="button" title="Ask ATLAS">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
  </button>

  <section id="senaite-aichat-panel" hidden="hidden">
    <div class="hdr">
      <div class="ava">A<span class="st"></span></div>
      <div class="meta">
        <div class="name">ATLAS</div>
        <div class="sub">LIMS assistant &middot; online</div>
      </div>
      <button class="x" id="senaite-aichat-close" type="button" title="Close">&times;</button>
    </div>
    <div id="senaite-aichat-log"></div>
    <div id="senaite-aichat-chips">
      <button type="button">How many samples?</button>
      <button type="button">List clients</button>
      <button type="button">Pending samples</button>
      <button type="button">Any anomalies?</button>
    </div>
    <div id="senaite-aichat-input-row">
      <input id="senaite-aichat-input" type="text" autocomplete="off"
             placeholder="Ask about a sample, status, remarks..." />
      <button id="senaite-aichat-send" type="button" title="Send">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </section>

  <script>
  //<![CDATA[
  (function () {
    var root  = document.getElementById('senaite-aichat-root');
    var btn   = document.getElementById('senaite-aichat-toggle');
    var panel = document.getElementById('senaite-aichat-panel');
    var close = document.getElementById('senaite-aichat-close');
    var input = document.getElementById('senaite-aichat-input');
    var send  = document.getElementById('senaite-aichat-send');
    var log   = document.getElementById('senaite-aichat-log');
    var chips = document.getElementById('senaite-aichat-chips');
    var url   = root.getAttribute('data-endpoint');
    var greeted = false;

    function esc(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    // Minimal markdown: **bold**, "- " bullet lists, line breaks.
    function md(s) {
      s = esc(s).replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
      var out = '', ul = false;
      s.split('\n').forEach(function (ln) {
        if (/^\s*[-*]\s+/.test(ln)) {
          if (!ul) { out += '<ul>'; ul = true; }
          out += '<li>' + ln.replace(/^\s*[-*]\s+/, '') + '</li>';
        } else {
          if (ul) { out += '</ul>'; ul = false; }
          out += ln.trim() === '' ? '' : '<div>' + ln + '</div>';
        }
      });
      if (ul) out += '</ul>';
      return out;
    }

    function bubble(role, text, asHtml) {
      var row = document.createElement('div');
      row.className = 'row ' + role;
      if (role === 'bot') {
        var av = document.createElement('div');
        av.className = 'av'; av.textContent = 'A';
        row.appendChild(av);
      }
      var b = document.createElement('div');
      b.className = 'bubble';
      if (asHtml) { b.innerHTML = md(text); } else { b.textContent = text; }
      row.appendChild(b);
      log.appendChild(row);
      log.scrollTop = log.scrollHeight;
      return row;
    }

    function showTyping() {
      var row = document.createElement('div');
      row.className = 'row bot'; row.id = 'atlas-typing';
      row.innerHTML = '<div class="av">A</div>' +
        '<div class="bubble typing"><span></span><span></span><span></span></div>';
      log.appendChild(row);
      log.scrollTop = log.scrollHeight;
    }
    function hideTyping() {
      var t = document.getElementById('atlas-typing');
      if (t) t.parentNode.removeChild(t);
    }

    function open() {
      panel.removeAttribute('hidden');
      if (!greeted) {
        greeted = true;
        bubble('bot', "Hi, I'm **ATLAS**. Ask me about samples, clients, " +
          "status (pending/approved), progress, remarks or anomalies.", true);
      }
      input.focus();
    }

    btn.addEventListener('click', function () {
      if (panel.hasAttribute('hidden')) open();
      else panel.setAttribute('hidden', 'hidden');
    });
    close.addEventListener('click', function () {
      panel.setAttribute('hidden', 'hidden');
    });

    function dispatch(text) {
      var msg = (text || input.value || '').trim();
      if (!msg) return;
      bubble('user', msg, false);
      input.value = '';
      input.disabled = true; send.disabled = true;
      showTyping();
      fetch(url + '?message=' + encodeURIComponent(msg), {
        method: 'GET', credentials: 'same-origin',
        headers: {'Accept': 'application/json'}
      }).then(function (r) { return r.json(); })
        .then(function (data) {
          hideTyping();
          if (data && data.ok) bubble('bot', data.reply || '(empty)', true);
          else bubble('bot', '[error] ' + (data && data.error || 'unknown'), false);
        })
        .catch(function (e) { hideTyping(); bubble('bot', '[network] ' + e, false); })
        .then(function () {
          input.disabled = false; send.disabled = false; input.focus();
        });
    }

    send.addEventListener('click', function () { dispatch(); });
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); dispatch(); }
    });
    chips.addEventListener('click', function (e) {
      if (e.target.tagName === 'BUTTON') dispatch(e.target.textContent);
    });
  })();
  //]]>
  </script>
</div>
